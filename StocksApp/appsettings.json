{
  "Serilog": {
    "MinimumLevel": "Information",
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.MSSqlServer",
      "Serilog.Sinks.Seq"
    ],
    "WriteTo":[
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Hour",
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true,
          "retainedFileCountLimit": 30
        }
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "Server=localhost;Database=StockAppLogs;User Id=sa;Password=Adham_2006#;TrustServerCertificate=True;",
          "tableName": "logs",
          "autoCreateSqlTable": true
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*",
  "TradingOptions":
  {
    "DefaultStockSymbol": "MSFT",
    "DefaultOrderQuantity": 100,
    "PopularStocks": ["AAPL","MSFT","AMZN","TSLA","GOOGL","GOOG","NVDA","BRK.B","META","UNH","JNJ","JPM","V","PG","XOM","HD","CVX","MA","BAC","ABBV","PFE","AVGO","COST","DIS","KO"]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=StockApp;User Id=sa;Password=Adham_2006#;TrustServerCertificate=True;"
  }
}
